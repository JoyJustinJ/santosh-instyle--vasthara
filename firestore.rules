rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Function to check if user is accessing their own data
    function isOwner(userId) {
      return request.auth.uid == userId || 
             (request.auth.token.phone_number != null && (
               request.auth.token.phone_number == userId || 
               getRawPhone() == userId
             ));
    }
    
    // Helper to get raw phone string (without +91) if it exists, otherwise empty string
    function getRawPhone() {
      return ('phone_number' in request.auth.token) ? request.auth.token.phone_number.replace('\\+91', '') : '';
    }

    // Helper to safely get the phone number itself
    function getFullPhone() {
      return ('phone_number' in request.auth.token) ? request.auth.token.phone_number : '';
    }

    // Safely check if a document exists and has a specific role (case-insensitive)
    function hasRole(docId, roleToCheck) {
      return docId != '' && 
             exists(/databases/$(database)/documents/users/$(docId)) &&
             (get(/databases/$(database)/documents/users/$(docId)).data.role == roleToCheck ||
              get(/databases/$(database)/documents/users/$(docId)).data.role == (roleToCheck.substring(0,1).upper() + roleToCheck.substring(1)));
    }

    // Function to check if user has admin role
    function isAdmin() {
      return isAuthenticated() && (
        hasRole(request.auth.uid, 'admin') ||
        hasRole(getRawPhone(), 'admin') ||
        hasRole(getFullPhone(), 'admin')
      );
    }
    
    // Function to check if user has staff or manager role
    function isStaffOrManager() {
      return isAuthenticated() && (
        hasRole(request.auth.uid, 'staff') ||
        hasRole(request.auth.uid, 'manager') ||
        hasRole(getRawPhone(), 'staff') ||
        hasRole(getRawPhone(), 'manager') ||
        hasRole(getFullPhone(), 'staff') ||
        hasRole(getFullPhone(), 'manager')
      );
    }

    // User profiles
    match /users/{userId} {
      allow read, write: if true;
    }
    
    // Schemes - Anyone can read, only Admins can manage
    match /schemes/{schemeId} {
      allow read, write: if true;
    }
    
    // User schemes (Active plans)
    match /user_schemes/{planId} {
      allow read, write: if true;
    }
    
    // Transactions
    match /transactions/{txId} {
      allow read, write: if true;
    }
    
    // Admin Settings and Sensitive data
    match /admins/{adminId} {
      allow read, write: if true;
    }
    
    match /settings/{settingId} {
      allow read, write: if true;
    }

    // Default deny (allow admin or staff for audit logs etc)
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
