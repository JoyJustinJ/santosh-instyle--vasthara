rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Function to check if user is accessing their own data
    function isOwner(userId) {
      return request.auth.uid == userId || 
             (request.auth.token.phone_number != null && (
               request.auth.token.phone_number == userId || 
               getRawPhone() == userId
             ));
    }
    
    // Helper to get raw phone string (without +91) if it exists, otherwise empty string
    function getRawPhone() {
      return request.auth.token.phone_number != null ? request.auth.token.phone_number.replace('\\+91', '') : '';
    }

    // Safely check if a document exists and has a specific role
    function hasRole(docId, roleToCheck) {
      return exists(/databases/$(database)/documents/users/$(docId)) &&
             get(/databases/$(database)/documents/users/$(docId)).data.role == roleToCheck;
    }

    // Function to check if user has admin role
    function isAdmin() {
      return isAuthenticated() && (
        hasRole(request.auth.uid, 'admin') ||
        (request.auth.token.phone_number != null && hasRole(getRawPhone(), 'admin')) ||
        (request.auth.token.phone_number != null && hasRole(request.auth.token.phone_number, 'admin'))
      );
    }
    
    // Function to check if user has staff or manager role
    function isStaffOrManager() {
      return isAuthenticated() && (
        hasRole(request.auth.uid, 'staff') ||
        hasRole(request.auth.uid, 'manager') ||
        (request.auth.token.phone_number != null && hasRole(getRawPhone(), 'staff')) ||
        (request.auth.token.phone_number != null && hasRole(getRawPhone(), 'manager')) ||
        (request.auth.token.phone_number != null && hasRole(request.auth.token.phone_number, 'staff')) ||
        (request.auth.token.phone_number != null && hasRole(request.auth.token.phone_number, 'manager'))
      );
    }

    // User profiles
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin() || isStaffOrManager());
      allow write: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }
    
    // Schemes - Anyone can read, only Admins can manage
    match /schemes/{schemeId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // User schemes (Active plans)
    match /user_schemes/{planId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin() || isStaffOrManager());
      allow write: if isAdmin() || isStaffOrManager(); // Admins and staff can record payments
    }
    
    // Transactions
    match /transactions/{txId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin() || isStaffOrManager());
      allow write: if isAdmin() || isStaffOrManager(); // Admins and staff can record transactions
    }
    
    // Admin Settings and Sensitive data
    match /admins/{adminId} {
      allow read, write: if isAdmin();
    }
    
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Default deny (allow admin or staff for audit logs etc)
    match /{document=**} {
      allow read, write: if isAdmin() || isStaffOrManager();
    }
  }
}
